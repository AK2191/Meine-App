rules_version = '2';

// CHANGE APP — Firestore Rules v7
// Nur Google-angemeldete User (kein Anonymous)

service cloud.firestore {
  match /databases/{database}/documents {

    // Echter Google-User (nicht anonym)
    function isGoogleUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Jeder authentifizierte User (für Settings-Fallback)
    function isAuth() {
      return request.auth != null;
    }

    // Spieler-Profile — nur Google-User dürfen schreiben
    match /change_players/{docId} {
      allow read: if true;
      allow write: if isGoogleUser();
    }

    // Challenge-Completions
    match /change_completions/{docId} {
      allow read: if true;
      allow write: if isGoogleUser();
    }

    // Challenges
    match /change_challenges/{challengeId} {
      allow read: if true;
      allow write: if isGoogleUser();
    }

    // Settings — auth reicht (auch wenn kurz kein currentUser)
    match /change_settings/{docId} {
      allow read, write: if isAuth();
    }

    // FCM Push Tokens
    match /change_push_tokens/{docId} {
      allow read, write: if isAuth();
    }

    // Fallback sperren
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
