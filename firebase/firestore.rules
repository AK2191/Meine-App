rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null && request.auth.token.email is string;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isAllowedEmail(email) {
      return email in ['ak2191@gmx.de', 'svenja.streit@googlemail.com'];
    }

    function isAllowedUser() {
      return isAuth() && isAllowedEmail(signedInEmail());
    }

    function isAdmin() {
      return isAllowedUser() && signedInEmail() == 'ak2191@gmx.de';
    }

    function ownDocId(docId) {
      return (signedInEmail() == 'ak2191@gmx.de' && docId == 'ak2191_gmx.de')
        || (signedInEmail() == 'svenja.streit@googlemail.com' && docId == 'svenja.streit_googlemail.com');
    }

    function ownEmail(value) {
      return value is string && value == signedInEmail();
    }

    function ownCompletion(data) {
      return (('email' in data) && ownEmail(data.email))
        || (('userEmail' in data) && ownEmail(data.userEmail))
        || (('playerId' in data) && ownEmail(data.playerId));
    }

    function noPublicPushToken(data) {
      return !data.keys().hasAny(['fcmToken']);
    }

    function isNudgeParticipant(data) {
      return data.from == signedInEmail() || data.to == signedInEmail();
    }

    match /change_players/{docId} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser()
        && ownDocId(docId)
        && ownEmail(request.resource.data.email)
        && noPublicPushToken(request.resource.data);
      allow delete: if false;
    }

    match /change_completions/{docId} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser()
        && ownCompletion(request.resource.data);
      allow delete: if isAllowedUser()
        && ownCompletion(resource.data);
    }

    match /change_challenges/{challengeId} {
      allow read: if isAllowedUser();
      allow create, update, delete: if isAdmin();
    }

    match /change_settings/{docId} {
      allow read, delete: if isAllowedUser() && ownDocId(docId);
      allow create, update: if isAllowedUser()
        && ownDocId(docId)
        && (!('owner' in request.resource.data) || ownEmail(request.resource.data.owner.email));
    }

    match /change_push_tokens/{docId} {
      allow read, delete: if isAllowedUser() && ownDocId(docId);
      allow create, update: if isAllowedUser()
        && ownDocId(docId)
        && ownEmail(request.resource.data.email);

      match /devices/{deviceId} {
        allow read, delete: if isAllowedUser() && ownDocId(docId);
        allow create, update: if isAllowedUser()
          && ownDocId(docId)
          && ownEmail(request.resource.data.email);
      }
    }

    match /change_events/{docId} {
      allow read, delete: if isAllowedUser() && ownDocId(docId);
      allow create, update: if isAllowedUser()
        && ownDocId(docId)
        && ownEmail(request.resource.data.email);

      match /items/{itemId} {
        allow read, delete: if isAllowedUser() && ownDocId(docId);
        allow create, update: if isAllowedUser()
          && ownDocId(docId)
          && ownEmail(request.resource.data.email);
      }
    }

    match /change_nudges/{nudgeId} {
      allow create: if isAllowedUser()
        && request.resource.data.keys().hasOnly(['from','fromName','to','toName','message','reason','sentAt','seen','createdAt'])
        && request.resource.data.keys().hasAll(['from','to','message','sentAt','seen'])
        && ownEmail(request.resource.data.from)
        && request.resource.data.to is string
        && isAllowedEmail(request.resource.data.to)
        && request.resource.data.to != request.resource.data.from
        && request.resource.data.message is string
        && request.resource.data.sentAt is string
        && request.resource.data.seen == false;
      allow read: if isAllowedUser() && isNudgeParticipant(resource.data);
      allow update: if isAllowedUser()
        && resource.data.to == signedInEmail()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seen','seenAt'])
        && request.resource.data.seen == true;
      allow delete: if isAllowedUser() && resource.data.from == signedInEmail();
    }

    match /change_pollen_symptoms/{docId} {
      allow create, update: if isAllowedUser()
        && ownEmail(request.resource.data.userEmail);
      allow read, delete: if isAllowedUser()
        && ownEmail(resource.data.userEmail);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
