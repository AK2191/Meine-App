rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// CHANGE APP — Firestore Rules v6
// Angepasst für GitHub Pages (kein COOP-Header):
// - Anonymous Auth als Fallback wenn Google-Login nicht möglich
// - Settings: read/write für alle authentifizierten User (Google + Anonym)
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Spieler-Profile
    match /change_players/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Challenge-Completions (Punkte)
    match /change_completions/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Challenges (Aufgaben)
    match /change_challenges/{challengeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Settings — Google-User oder Anonymous-User (GitHub Pages Fallback)
    match /change_settings/{docId} {
      allow read, write: if isAuth();
    }

    // FCM Push Tokens
    match /change_push_tokens/{docId} {
      allow read, write: if isAuth();
    }

    // Fallback: alles andere sperren
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
