rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// CHANGE APP — Firestore Rules v5
// Firestore-Zugriff nur mit Firebase Auth.
// Die App meldet sich nach dem Google-Login zusätzlich per Firebase Auth an.
// Wichtig: Keine offenen Schreibrechte ohne request.auth.
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Spieler-Profile
    // Lesen: offen (Rangliste)
    // Schreiben: nur eingeloggte Nutzer
    match /change_players/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Challenge-Completions (Punkte)
    // Lesen: offen (Rangliste/Punkte)
    // Schreiben: nur eingeloggte Nutzer
    match /change_completions/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Challenges (Aufgaben)
    // Lesen: offen
    // Schreiben: nur eingeloggte Nutzer
    match /change_challenges/{challengeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Settings (Einstellungen)
    // Nur eingeloggte Nutzer
    match /change_settings/{docId} {
      allow read, write: if isAuth();
    }

    // FCM Push Tokens
    match /change_push_tokens/{docId} {
      allow read, write: if isAuth();
    }

    // Fallback: alles andere sperren
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
